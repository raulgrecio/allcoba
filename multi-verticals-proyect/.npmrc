# Block all postinstall scripts by default for supply-chain safety.
# To rebuild a specific package when needed: pnpm rebuild <package>
ignore-scripts=true

# Avoid pnpm 11 auto-rerun of `install` before every script — it would
# re-emit ERR_PNPM_IGNORED_BUILDS and crash turbo. We trust the lockfile.
verify-deps-before-run=false
