{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "#*": ["src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "src/**/*",
    "__tests__/**/*",
    "scripts/**/*",
    "drizzle.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist", "__tests__.legacy"]
}
