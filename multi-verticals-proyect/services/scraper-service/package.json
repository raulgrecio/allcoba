{
  "name": "@allcoba/scraper-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/index.ts",
    "scrape": "npm run cli -- scrape",
    "discover": "npm run cli -- discover",
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@allcoba/kernel": "workspace:*",
    "@allcoba/shared-types": "workspace:*",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.2",
    "i18n-iso-countries": "^7.14.0",
    "libphonenumber-js": "^1.13.3",
    "patchright": "^1.60.0",
    "pg-boss": "^12.18.2",
    "pino": "^10.3.1",
    "playwright-core": "^1.60.0",
    "postgres": "^3.4.9",
    "robots-parser": "^3.0.1",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
