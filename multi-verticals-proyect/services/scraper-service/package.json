{
  "name": "@allcoba/scraper-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/index.ts",
    "scrape": "npm run cli -- scrape",
    "discover": "npm run cli -- discover",
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@allcoba/legacy-domain": "workspace:*",
    "@allcoba/kernel": "workspace:*",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.2",
    "i18n-iso-countries": "^7.14.0",
    "patchright": "^1.59.4",
    "pg-boss": "^10.1.0",
    "pino": "^9.5.0",
    "playwright-core": "^1.59.1",
    "postgres": "^3.4.9",
    "robots-parser": "^3.0.1",
    "sharp": "^0.33.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.1.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
