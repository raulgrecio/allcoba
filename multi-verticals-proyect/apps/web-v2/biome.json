{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              "react",
              "react/**",
              "vitest",
              "vitest/**",
              ":NODE:",
              ":PACKAGE:",
              ":BLANK_LINE:",
              "@allcoba/**",
              ":BLANK_LINE:",
              "#/**",
              ":BLANK_LINE:",
              "./**",
              "../**"
            ]
          }
        }
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
